# PostgreSQL Database
POSTGRES_DB=beatport2rss
POSTGRES_USER=db@beatport2rss.com
POSTGRES_PASSWORD=your_secure_password_here

# Beatport Credentials
BEATPORT_USERNAME=your_beatport_username
BEATPORT_PASSWORD=your_beatport_password

# Chromium Downloader
CHROMIUM_BASE_URL=https://download-chromium.appspot.com

# Token Interceptor
TOKEN_INTERCEPTOR_GRPC_URI=http://0.0.0.0:5000

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672